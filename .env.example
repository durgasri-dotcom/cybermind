# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Pinecone (leave empty to use FAISS locally) ─────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=cybermind-threats
USE_PINECONE=false

# ── LLM Config ────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-70b-versatile
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# ── App Config ────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Embedding Config ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Risk Score Thresholds ─────────────────────────────────────────────────────
RISK_SCORE_CRITICAL=0.85
RISK_SCORE_HIGH=0.65
RISK_SCORE_MEDIUM=0.40
```